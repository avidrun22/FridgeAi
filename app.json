{
  "expo": {
    "name": "fridgeai-native",
    "slug": "fridgeai-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gregorygoldberg.fridgeai",
      "infoPlist": {
        "NSCameraUsageDescription": "FridgeAI needs camera access to scan barcodes",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0F0A",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "permissions": ["android.permission.CAMERA", "android.permission.INTERNET"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "FridgeAI needs camera access to scan barcodes"
        }
      ]
    ]
  }
}
